# ---- Backend (.env at the project root, for local dev) ----

# JWT signing secret (any long random string)
SECRET=change-me-to-a-long-random-string

# MongoDB connection strings
DEV_MONGO_URL=mongodb://127.0.0.1:27017/ipl-auction
PROD_MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ipl-auction

# URL of your deployed frontend, used for CORS + cookie origin.
# In production this is your Vercel URL, e.g. https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# Optional: override the listening port (Render sets this automatically)
PORT=8000
