{
  "name": "ipl-auction",
  "version": "1.0.0",
  "description": "An Ipl auction application",
  "main": "app.js",
  "engines": {
    "node": "18.x"
  },
  "scripts": {
    "start": "node app.js",
    "client-install": "npm install --prefix client",
    "server": "nodemon app.js",
    "client": "npm start --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "node -e \"if (process.env.CI || process.env.NODE_ENV === 'production') process.exit(0); require('child_process').execSync('husky install', {stdio:'inherit'})\"",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "author": "Srinivas",
  "license": "ISC",
  "dependencies": {
    "axios": "^0.21.2",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.5",
    "cors": "^2.8.5",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "helmet": "^4.5.0",
    "jsdom": "^16.5.3",
    "jsonwebtoken": "^8.5.1",
    "mongoose": "^6.0.7",
    "morgan": "^1.10.0",
    "socket.io": "^4.1.2"
  },
  "devDependencies": {
    "concurrently": "^6.2.1",
    "husky": "^7.0.0",
    "prettier": "2.4.1"
  }
}
